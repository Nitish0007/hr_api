#!/bin/bash
set -e

# Remove any pre-existing server.pid for clean restarts
rm -f /rails/tmp/pids/server.pid

# 1. Check if gems are missing, if so, install them
bundle check || bundle install --with development test

# 2. DB prpare
if [ "$RAILS_ENV" = "test" ]; then
  # db:prepare without seeding
  bin/rails db:migrate
else
  bin/rails db:prepare
fi

# 3. Execute the CMD
exec "$@"